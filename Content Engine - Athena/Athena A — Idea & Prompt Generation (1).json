    {
      "parameters": {
        "jsCode": "const raw = $json.content[0].text;\nreturn [{ json: { \n  type_of_raw: typeof raw,\n  first_100: raw.substring(0, 100),\n  length: raw.length\n} }];"
      },
      "id": "2b823d9a-34c5-46b6-a3dd-d4da6cc8ec7f",
      "name": "Parse Ideas JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1472,
        96
      ]
    },
    {
      "parameters": {
        "jsCode": "const allIdeas = $input.all().map(i => i.json);\n\nconst system = [\n  'You are a strict content quality reviewer for Athena SAT prep content. For each idea evaluate:',\n  '1. Is the concept visually concrete enough to render as a single image?',\n  '2. Does it align with the Athena brand — personalized teacher, not AI product?',\n  '3. Would it genuinely resonate with parents of high-schoolers or students feeling stuck?',\n  '4. Is it fresh and not a tired SAT prep cliche?',\n  '',\n  'Return ONLY a raw JSON array, same length and same order as input. Each object: {idea_id, keep (boolean), reason (brief string)}. No markdown. No preamble.'\n].join('\\n');\n\nreturn [{ json: { body: {\n  model: 'claude-sonnet-4-6',\n  max_tokens: 2000,\n  system,\n  messages: [{ role: 'user', content: 'Review and filter these ideas:\\n' + JSON.stringify(allIdeas, null, 2) }]\n} } }];"
      },
      "id": "f4a742fe-0124-4bf2-9b71-ee3b13ade49d",
      "name": "Build Filter Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1728,
