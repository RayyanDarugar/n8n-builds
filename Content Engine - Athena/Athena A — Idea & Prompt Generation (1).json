    {
      "parameters": {
        "jsCode": "const config = $('Read Config Sheet').all();\nconst configMap = {};\nconfig.forEach(item => { configMap[item.json.category] = item.json; });\n\nconst batchSize = parseInt($('Batch Form Trigger').first().json['Number of ideas to generate']) || 10;\nconst categoryFocus = $('Batch Form Trigger').first().json['Category focus (leave blank for All)'] || 'All';\nconst allCats = ['SAT_MYTH', 'BRAIN_TEASER', 'NOTES_APP', 'COMIC', 'BEAGLE_EXPLAINS'];\nconst active = categoryFocus === 'All' ? allCats : [categoryFocus];\n\nconst guides = active.map(cat => {\n  const guide = (configMap[cat] || {}).style_guide || '[No style guide — fill in Config sheet]';\n  return '=== ' + cat + ' ===\\n' + guide;\n}).join('\\n\\n');\n\nconst system = [\n  'You are the creative content strategist for Athena, an SAT prep platform.',\n  '',\n  'NON-NEGOTIABLE BRAND RULES:',\n  '- Athena is a personalized TEACHER, never an AI product, dashboard, or analytics tool',\n  '- Core outcome: Ohhhh... now I get it.',\n  '- Mascot: A cute Beagle dog — curious, friendly, slightly goofy. The Beagle is the guide/student in content, never the product.',\n  '- Primary audience: Parents aged 35-55 worried about SAT scores, college admissions, tutoring costs, their kid feeling stuck.',\n  '- NEVER lead with: AI-powered, adaptive learning, algorithms, analytics, dashboards.',\n  '',\n  'CRITICAL INSTRUCTION FOR final_prompt:',\n  'The final_prompt is sent DIRECTLY to an AI image generation model with no other context.',\n  'Structure every final_prompt as: [full category style guide text verbatim] followed by [the specific content for this idea].',\n  'Do NOT summarize the style guide. Embed it in full so the image model has everything it needs.',\n  '',\n  'ACTIVE STYLE GUIDES:',\n  guides,\n  '',\n  'OUTPUT: Respond with ONLY a raw JSON array. No markdown fences. No preamble. Each object must have exactly: idea_id (unique string), category (one of the active categories), concept (one sentence), final_prompt (complete verbose image generation prompt).'\n].join('\\n');\n\nconst user = categoryFocus === 'All'\n  ? 'Generate exactly ' + batchSize + ' content ideas distributed roughly evenly across: ' + active.join(', ') + '.'\n  : 'Generate exactly ' + batchSize + ' content ideas for the ' + categoryFocus + ' category.';\n\nreturn [{ json: { body: {\n  model: 'claude-sonnet-4-6',\n  max_tokens: 20000,\n  system,\n  messages: [{ role: 'user', content: user }]\n} } }];"
      },
      "id": "7edd8369-37de-4a2a-83d8-895468f200cf",
      "name": "Build Claude Prompt Request",
