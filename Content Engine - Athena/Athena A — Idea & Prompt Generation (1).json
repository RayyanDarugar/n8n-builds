    {
      "parameters": {
        "jsCode": "const raw = $json.content[0].text;\n\nfunction safeParse(text) {\n  let s = text.trim();\n  s = s.replace(/^```json\\s*/i, '').replace(/^```\\s*/, '').replace(/\\s*```$/, '').trim();\n  return JSON.parse(s);\n}\n\nlet decisions;\ntry {\n  decisions = safeParse(raw);\n} catch(e) {\n  throw new Error('Filter response parse failed: ' + e.message);\n}\n\nconst map = {};\ndecisions.forEach(d => { map[d.idea_id] = d; });\n\nconst originals = $('Parse Ideas JSON').all().map(i => i.json);\n\nreturn originals.map(idea => {\n  const d = map[idea.idea_id] || { keep: true, reason: 'no decision returned — defaulting to keep' };\n  return { json: Object.assign({}, idea, { ai_keep: d.keep, ai_filter_reason: d.reason }) };\n});"
      },
