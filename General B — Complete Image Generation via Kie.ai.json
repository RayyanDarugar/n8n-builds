        "jsCode": "const config = $('Read Config Sheet').all();\nconst configMap = {};\nconfig.forEach(item => { configMap[item.json.category] = item.json; });\n\nconst staging = $('Read Staging Sheet').all();\nconst review  = $('Read Review Sheet').all();\n\nconst approvedStaging = staging.filter(i => {\n  const approved = i.json.your_approval === true || String(i.json.your_approval).toUpperCase() === 'TRUE';\n  const pending  = (i.json.status || '').toLowerCase() === 'pending_review';\n  return approved && pending;\n});\n\nconst needsRefinement = review.filter(i =>\n  (i.json.status || '').toLowerCase() === 'needs refinement'\n);\n\nconst merged = [];\n\napprovedStaging.forEach(item => {\n  const cfg = configMap[item.json.category] || {};\n  const content = item.json.concept || item.json.final_prompt || '';\n  merged.push(Object.assign({}, item.json, {\n    source: 'new',\n    resolved_prompt: content,\n    style_guide: cfg.style_guide || '',\n    style_ref_url: cfg.style_ref_url || ''\n  }));\n});\n\nneedsRefinement.forEach(item => {\n  const cfg     = configMap[item.json.category] || {};\n  const notes   = item.json.refinement_notes || '';\n  const content = item.json.concept || item.json.final_prompt || '';\n  const prompt  = content + (notes ? '\\n\\nRefinement notes: ' + notes : '');\n  merged.push(Object.assign({}, item.json, {\n    source: 'refinement',\n    resolved_prompt: prompt,\n    style_guide: cfg.style_guide || '',\n    style_ref_url: cfg.style_ref_url || ''\n  }));\n});\n\nif (merged.length === 0) {\n  throw new Error('Nothing to process. Approve rows in Staging or mark rows as Needs Refinement in Review.');\n}\n\nreturn merged.map(item => ({ json: item }));"
      },
