    {
      "parameters": {
        "jsCode": "const original = $('Split In Batches').item.json;\nconst kieStyleUrl = $json.data.downloadUrl;\nif (!kieStyleUrl) throw new Error('Style ref upload failed — no downloadUrl in response: ' + JSON.stringify($json).substring(0, 300));\nreturn [{ json: Object.assign({}, original, { kie_style_url: kieStyleUrl }) }];"
      },
      "id": "18e71ea8-3fce-4f24-9877-98d641403ed4",
      "name": "Attach Style URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1472,
        672
      ]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst refs = [];\nif (item.kie_style_url) refs.push(item.kie_style_url);\n\nconst fullPrompt = (item.style_guide || '') +\n  '\\n\\nSPECIFIC CONTENT FOR THIS IMAGE:\\n' + item.resolved_prompt +\n  '\\n\\nReference the provided style image to maintain visual consistency in palette, illustration style, and layout.';\n\nreturn [{ json: Object.assign({}, item, {\n  full_prompt: fullPrompt,\n  kie_body: {\n    model: 'gpt-image-2-image-to-image',\n    input: {\n      prompt: fullPrompt,\n      input_urls: refs,\n      aspect_ratio: '4:5'\n    }\n  }\n}) }];"
      },
      "id": "7448ecc7-239b-4bbd-8a38-1325a4dd35ee",
      "name": "Build Kie Request",
