        "jsCode": "const statusData = $json;\nconst prior      = $('Wait Before Poll').item.json;\nconst polls      = (prior.poll_count || 0) + 1;\n\nconst d     = (statusData && statusData.data) || {};\nconst state = d.state;\n\n// Try both known result URL paths\nconst result          = JSON.parse(d.resultJson || '{\"resultUrls\":[]}');\nconst result_image_url = result.resultUrls[0] || null;\n\n\nlet nextAction;\nif (state === 'success') nextAction = 'continue';\nelse if (polls >= 20)    nextAction = 'fail';\nelse                     nextAction = 'retry';\n\nreturn [{ json: Object.assign({}, prior, {\n  poll_count:       polls,\n  next_action:      nextAction,\n  result_image_url: result_image_url,\n  poll_status:      state || 'unknown'\n}) }];"
